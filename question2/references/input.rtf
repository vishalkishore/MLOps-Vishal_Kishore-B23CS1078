\uc0\u2479 \u2494 \u2480 \u2494  \u2472 \u2495 \u2479 \u2492 \u2478 \u2495 \u2468  \u2476 \u2439  \u2474 \u2465 \u2492 \u2503  \u2447 \u2476 \u2434  \u2472 \u2468 \u2497 \u2472  \u2471 \u2494 \u2480 \u2467 \u2494  \u2472 \u2495 \u2479 \u2492 \u2503  \u2458 \u2495 \u2472 \u2509 \u2468 \u2494  \u2453 \u2480 \u2503 , \u2468 \u2494 \u2480 \u2494  \u2488 \u2494 \u2471 \u2494 \u2480 \u2467 \u2468  \u2488 \u2478 \u2488 \u2509 \u2479 \u2494 \u2480  \u2488 \u2478 \u2494 \u2471 \u2494 \u2472  \u2437 \u2472 \u2509 \u2479 \u2470 \u2503 \u2480  \u2468 \u2497 \u2482 \u2472 \u2494 \u2479 \u2492  \u2470 \u2509 \u2480 \u2497 \u2468  \u2454 \u2497 \u2433 \u2460 \u2503  \u2474 \u2494 \u2479 \u2492 \u2404 \
\
\uc0\u2470 \u2496 \u2480 \u2509 \u2456  \u2438 \u2482 \u2507 \u2458 \u2472 \u2494 \u2480  \u2474 \u2480 \u2451  \u2479 \u2454 \u2472  \u2453 \u2507 \u2472 \u2507  \u2488 \u2495 \u2470 \u2509 \u2471 \u2494 \u2472 \u2509 \u2468 \u2503  \u2474 \u2508 \u2433 \u2459 \u2494 \u2472 \u2507  \u2455 \u2503 \u2482  \u2472 \u2494 , \u2468 \u2454 \u2472  \u2453 \u2478 \u2495 \u2463 \u2495  \u2476 \u2495 \u2487 \u2479 \u2492 \u2463 \u2495  \u2474 \u2480 \u2476 \u2480 \u2509 \u2468 \u2496  \u2476 \u2504 \u2464 \u2453  \u2474 \u2480 \u2509 \u2479 \u2472 \u2509 \u2468  \u2488 \u2509 \u2469 \u2455 \u2495 \u2468  \u2480 \u2494 \u2454 \u2494 \u2480  \u2488 \u2495 \u2470 \u2509 \u2471 \u2494 \u2472 \u2509 \u2468  \u2472 \u2503 \u2479 \u2492 \u2404 \
\
\uc0\u2479 \u2470 \u2495 \u2451  \u2463 \u2509 \u2480 \u2503 \u2472 \u2463 \u2495  \u2472 \u2495 \u2480 \u2509 \u2471 \u2494 \u2480 \u2495 \u2468  \u2488 \u2478 \u2479 \u2492 \u2503 \u2480  \u2437 \u2472 \u2503 \u2453  \u2474 \u2480 \u2503  \u2474 \u2508 \u2433 \u2459 \u2503 \u2459 \u2495 \u2482 , \u2479 \u2494 \u2468 \u2509 \u2480 \u2496 \u2480 \u2494  \u2471 \u2504 \u2480 \u2509 \u2479  \u2471 \u2480 \u2503  \u2437 \u2474 \u2503 \u2453 \u2509 \u2487 \u2494  \u2453 \u2480 \u2503 \u2459 \u2495 \u2482 \u2503 \u2472  \u2453 \u2494 \u2480 \u2467  \u2476 \u2495 \u2453 \u2482 \u2509 \u2474  \u2453 \u2507 \u2472 \u2507  \u2476 \u2509 \u2479 \u2476 \u2488 \u2509 \u2469 \u2494  \u2459 \u2495 \u2482  \u2472 \u2494 \u2404 \
\
\uc0\u2438 \u2478 \u2480 \u2494  \u2479 \u2468  \u2476 \u2503 \u2486 \u2495  \u2474 \u2509 \u2480 \u2479 \u2497 \u2453 \u2509 \u2468 \u2495 \u2480  \u2441 \u2474 \u2480  \u2472 \u2495 \u2480 \u2509 \u2477 \u2480 \u2486 \u2496 \u2482  \u2489 \u2479 \u2492 \u2503  \u2441 \u2464 \u2459 \u2495 , \u2468 \u2468  \u2476 \u2503 \u2486 \u2495  \u2476 \u2509 \u2479 \u2453 \u2509 \u2468 \u2495 \u2455 \u2468  \u2468 \u2469 \u2509 \u2479 \u2503 \u2480  \u2472 \u2495 \u2480 \u2494 \u2474 \u2468 \u2509 \u2468 \u2494  \u2472 \u2495 \u2486 \u2509 \u2458 \u2495 \u2468  \u2453 \u2480 \u2494 \u2480  \u2474 \u2509 \u2480 \u2479 \u2492 \u2507 \u2460 \u2472 \u2496 \u2479 \u2492 \u2468 \u2494 \u2451  \u2476 \u2494 \u2465 \u2492 \u2459 \u2503 .}